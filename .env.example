# ===== Frontend (Next.js) =====
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SOCKET_URL=ws://localhost:4000
NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_SENTRY_DSN=

# ===== Backend (Fastify) =====
PORT=4000
# Neon: dashboard → Connect → "Connection string" (keep ?sslmode=require)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pulse
# Upstash TCP endpoint: rediss://default:<REST_TOKEN>@<db-name>.upstash.io:6379
REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
JWT_SECRET=change-me
CORS_ORIGIN=http://localhost:3000
SENTRY_DSN=

# ===== TxLINE =====
TXLINE_NETWORK=devnet
TXLINE_BASE_URL=https://txline-dev.txodds.com
# Devnet free World Cup tier = service level 1; mainnet real-time = 12
TXLINE_SERVICE_LEVEL=1
TXLINE_SUBSCRIPTION_WEEKS=4
# Server wallet for the on-chain subscribe tx (auto-generated on first run; fund with devnet SOL)
TXLINE_WALLET_PATH=./.keys/txline-wallet.json
SOLANA_RPC_URL=https://api.devnet.solana.com

# OpenRouter (demo/replay data generation only — NOT used for live mode)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-3.5-flash
